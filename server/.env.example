# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
# Set NODE_ENV=production on your host (Render sets this via render.yaml).
# It enables SSL for the DB and secure cookies.
# NODE_ENV=production

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Production: a single managed connection string takes priority if present.
# DATABASE_URL=postgres://user:password@host:5432/dbname
#
# Local development: individual settings (used when DATABASE_URL is unset).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=truelancer_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# ── Auth ──────────────────────────────────────────────────────────────────────
# Use long, random strings in production (e.g. `openssl rand -hex 32`)
JWT_SECRET=change_me_to_a_long_random_string
SESSION_SECRET=change_me_to_a_long_random_string

# ── AI (Groq) ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── Frontend origin (used for CORS + OAuth redirect) ──────────────────────────
FRONTEND_URL=http://localhost:5200
